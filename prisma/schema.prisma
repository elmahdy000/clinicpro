generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Clinic {
  id                 Int      @id @default(autoincrement())
  name               String
  address            String?
  phone              String?
  subscriptionPlan   String   @default("FREE")
  subscriptionStatus String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users          User[]
  doctors        Doctor[]
  clinicPatients ClinicPatient[]
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  prescriptions  Prescription[]
  invoices       Invoice[]
  fileUploads    FileUpload[]
  auditLogs      AuditLog[]
  settings       ClinicSettings?
}

model ClinicSettings {
  id        Int      @id @default(autoincrement())
  clinicId  Int      @unique
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  currency  String   @default("EGP")
  timezone  String   @default("Africa/Cairo")
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  clinicId  Int?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  email     String   @unique
  password  String
  name      String
  role      String   @default("PATIENT") // Roles: PLATFORM_OWNER, CLINIC_ADMIN, DOCTOR, NURSE, RECEPTIONIST, PATIENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorProfile  Doctor?    @relation("DoctorProfile")
  patientProfile Patient?   @relation("PatientProfile")
  auditLogs      AuditLog[]
}

model Doctor {
  id              Int                  @id @default(autoincrement())
  clinicId        Int
  clinic          Clinic               @relation(fields: [clinicId], references: [id])
  user            User                 @relation("DoctorProfile", fields: [userId], references: [id])
  userId          Int                  @unique
  specialization  String
  consultationFee Float
  status          String
  appointments    Appointment[]        @relation("AppointmentDoctor")
  medicalRecords  MedicalRecord[]      @relation("MedicalRecordDoctor")
  prescriptions   Prescription[]       @relation("PrescriptionDoctor")
  invoices        Invoice[]
  availability    DoctorAvailability[]
  timeOff         DoctorTimeOff[]
}

model DoctorAvailability {
  id           Int     @id @default(autoincrement())
  doctor       Doctor  @relation(fields: [doctorId], references: [id])
  doctorId     Int
  dayOfWeek    Int // 0=Sun, 1=Mon ... 6=Sat
  startTime    String // HH:mm format
  endTime      String // HH:mm format
  slotDuration Int     @default(30) // minutes per slot
  isAvailable  Boolean @default(true)

  @@unique([doctorId, dayOfWeek])
}

model DoctorTimeOff {
  id       Int      @id @default(autoincrement())
  doctor   Doctor   @relation(fields: [doctorId], references: [id])
  doctorId Int
  date     DateTime
  reason   String?

  @@unique([doctorId, date])
}

model Patient {
  id               Int       @id @default(autoincrement())
  firstName        String
  lastName         String
  email            String?   @unique
  phone            String?   @unique
  nationalId       String?   @unique
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  governorate      String?
  city             String?
  bloodGroup       String?
  allergies        String?
  medicalHistory   String?
  emergencyContact String?
  emailVerifiedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  appointments   Appointment[]   @relation("AppointmentPatient")
  medicalRecords MedicalRecord[] @relation("MedicalRecordPatient")
  prescriptions  Prescription[]  @relation("PrescriptionPatient")
  invoices       Invoice[]
  user           User?           @relation("PatientProfile", fields: [userId], references: [id])
  userId         Int?            @unique

  clinics        ClinicPatient[]
}

model ClinicPatient {
  id        Int      @id @default(autoincrement())
  clinicId  Int
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientId Int
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([clinicId, patientId])
}

model Appointment {
  id                 Int            @id @default(autoincrement())
  clinicId           Int
  clinic             Clinic         @relation(fields: [clinicId], references: [id])
  patient            Patient        @relation("AppointmentPatient", fields: [patientId], references: [id])
  patientId          Int
  doctor             Doctor         @relation("AppointmentDoctor", fields: [doctorId], references: [id])
  doctorId           Int
  appointmentDate    DateTime
  appointmentEndDate DateTime
  invoices           Invoice[]
  durationMinutes    Int            @default(30)
  type               String
  reason             String?
  status             String         @default("PENDING")
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  medicalRecord      MedicalRecord? @relation("AppointmentMedicalRecord")
}

model MedicalRecord {
  id             Int           @id @default(autoincrement())
  clinicId       Int
  clinic         Clinic        @relation(fields: [clinicId], references: [id])
  patient        Patient       @relation("MedicalRecordPatient", fields: [patientId], references: [id])
  patientId      Int
  doctor         Doctor        @relation("MedicalRecordDoctor", fields: [doctorId], references: [id])
  doctorId       Int
  appointment    Appointment?  @relation("AppointmentMedicalRecord", fields: [appointmentId], references: [id])
  appointmentId  Int?          @unique
  chiefComplaint String
  diagnosis      String
  treatmentPlan  String
  vitalSigns     String
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  prescription   Prescription? @relation("PrescriptionMedicalRecord")
}

model Prescription {
  id              Int            @id @default(autoincrement())
  clinicId        Int
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  patient         Patient        @relation("PrescriptionPatient", fields: [patientId], references: [id])
  patientId       Int
  doctor          Doctor         @relation("PrescriptionDoctor", fields: [doctorId], references: [id])
  doctorId        Int
  medicalRecord   MedicalRecord? @relation("PrescriptionMedicalRecord", fields: [medicalRecordId], references: [id])
  medicalRecordId Int?           @unique
  prescribedDate  DateTime       @default(now())
  medications     String?        // Legacy text field, migrating to items
  instructions    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items           PrescriptionItem[]
}

model Invoice {
  id            Int          @id @default(autoincrement())
  clinicId      Int
  clinic        Clinic       @relation(fields: [clinicId], references: [id])
  invoiceNumber String
  patientId     Int
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      Int?
  doctor        Doctor?      @relation(fields: [doctorId], references: [id])
  appointmentId Int?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  items         String
  subtotal      Float
  tax           Float        @default(0)
  discount      Float        @default(0)
  total         Float
  status        String       @default("PENDING")
  paymentMethod String?
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([clinicId, invoiceNumber])
}

model FileUpload {
  id         Int      @id @default(autoincrement())
  clinicId   Int
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
  fileName   String
  fileType   String
  url        String
  uploadedBy Int
  uploadedAt DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  clinicId  Int
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id            Int      @id @default(autoincrement())
  userId        Int
  title         String
  message       String
  type          String   @default("INFO")
  referenceType String?
  referenceId   Int?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model OtpVerification {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model Medication {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  activeIngredient String?
  manufacturer     String?
  category         String?
  strength         String?  // e.g. "500mg", "10mg/5ml"
  form             String?  // e.g. "أقراص", "شراب", "حقن"
  isGlobal         Boolean  @default(true)  // true = platform medicine, false = clinic custom
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  prescriptionItems PrescriptionItem[]
}

model PrescriptionItem {
  id             Int          @id @default(autoincrement())
  prescriptionId Int
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicationId   Int
  medication     Medication   @relation(fields: [medicationId], references: [id])
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
